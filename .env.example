# ── Server ──────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MySQL ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=fixitnow

# ── JWT ──────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# ── Nafath ───────────────────────────────────────
NAFAZ_URL=https://nafath.api.elm.sa
NAFAZ_APP_ID=your_nafaz_app_id
NAFAZ_APP_KEY=your_nafaz_app_key
NAFAZ_SERVICE=your_nafaz_service

# ── Yakeen ───────────────────────────────────────
YAKERN_USERNAME=your_yakeen_username
YAKERN_PASSWORD=your_yakeen_password
YAKERN_APP_ID=your_yakeen_app_id
YAKERN_APP_KEY=your_yakeen_app_key

# ── Tahaqq ───────────────────────────────────────
TAHAQQ_URL=https://tahaqq.api.elm.sa
TAHAQQ_APP_ID=your_tahaqq_app_id
TAHAQQ_APP_KEY=your_tahaqq_app_key
TAHAQQ_SERVICE_KEY=your_service_key
TAHAQQ_ORGANIZATION_NUMBER=your_org_number

# ── Dakhli (GOSI) ────────────────────────────────
DAKHLI_APP_ID=your_dakhli_app_id
DAKHLI_APP_KEY=your_dakhli_app_key
DAKHLI_PLATFORM_KEY=your_platform_key
DAKHLI_ORGANIZATION_NUMBER=your_org_number

# ── Government Payslip ────────────────────────────
GOV_APP_ID=your_gov_app_id
GOV_APP_KEY=your_gov_app_key
GOV_PLATFORM_KEY=your_gov_platform_key
GOV_ORGANIZATION_NUMBER=your_gov_org_number

# ── LeanTech (IBAN) ───────────────────────────────
LEAN_CLIENT_ID=your_lean_client_id
LEAN_CLIENT_SECRET=your_lean_client_secret
LEAN_APP_TOKEN=your_lean_app_token

# ── Email ─────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=verification@tayseerme.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=Tayseer Arabian Company <verification@tayseerme.com>

# ── SMS ───────────────────────────────────────────
SMS_API_URL=https://sms.provider.com/send
SMS_API_KEY=your_sms_api_key
SMS_SENDER=AL-TAYSEER

# ── Upload ────────────────────────────────────────
UPLOAD_DIR=uploads/fixitnow
